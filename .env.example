# Copy to .env and fill in. NEVER commit the real .env (it's git-ignored).
#   cp .env.example .env
# Then load it before running the CRM-push scripts:
#   set -a && source .env && set +a

# HubSpot Private App token (Settings -> Integrations -> Private Apps).
# Scopes: crm.objects.companies.read/write, crm.objects.contacts.read/write,
#         crm.schemas.companies.read/write, crm.schemas.contacts.read/write
HUBSPOT_TOKEN=pat-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Contact address advertised by the website scraper's User-Agent (be reachable).
SCRAPER_CONTACT=you@example.com
